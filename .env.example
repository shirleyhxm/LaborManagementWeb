# Application Environment
# Options: development, staging, production
VITE_APP_ENV=development

# API Configuration
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8080/api

# Feature Flags
# Enable/disable new optimization workflow (true/false)
VITE_FEATURE_OPTIMIZATION_WORKFLOW=true
# Enable/disable legacy hardcoded features (true/false)
VITE_FEATURE_LEGACY_UI=false

# Authentication
# JWT token expiration time in minutes (default: 15)
VITE_AUTH_TOKEN_EXPIRY=15
# Refresh token expiration time in days (default: 7)
VITE_AUTH_REFRESH_TOKEN_EXPIRY=7

# Monitoring & Analytics (Optional)
# Sentry DSN for error tracking
VITE_SENTRY_DSN=
# Google Analytics tracking ID
VITE_GA_TRACKING_ID=
# Environment name for monitoring (e.g., production, staging)
VITE_MONITORING_ENV=development

# API Configuration
# Request timeout in milliseconds (default: 30000 = 30 seconds)
VITE_API_TIMEOUT=30000
# Maximum retry attempts for failed requests (default: 3)
VITE_API_MAX_RETRIES=3

# Security
# Enable HTTPS-only mode (true/false)
VITE_FORCE_HTTPS=false
# Enable Content Security Policy (true/false)
VITE_ENABLE_CSP=true

# Logging
# Log level: debug, info, warn, error (default: info)
VITE_LOG_LEVEL=info
# Enable console logging in production (true/false)
VITE_ENABLE_CONSOLE_LOGS=false
